---
import BaseLayout from '../layouts/BaseLayout.astro';
import { kampung, potensiUnggulan } from '../data/kampung';
---

<BaseLayout 
  title="Potensi Kampung"
  description={`Empat sektor unggulan ${kampung.namaLengkap}: pariwisata, pertanian, perkebunan, dan perikanan. Kekayaan alam dan budaya Kalimantan Timur.`}
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-sawah-100 via-krem-100 to-sunset-100 pattern-dayak relative overflow-hidden">
    <div class="absolute top-10 left-10 w-72 h-72 bg-sawah-400/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-sunset-400/20 rounded-full blur-3xl"></div>
    
    <div class="container-section py-20 md:py-24 relative">
      <div class="max-w-4xl">
        <div class="eyebrow mb-4">Potensi Unggulan</div>
        <h1 class="headline-display text-tanah-900 mb-6 text-balance">
          Empat pilar, satu <span class="highlight-brush">kampung</span>.
        </h1>
        <p class="text-xl text-tanah-700 leading-relaxed max-w-3xl text-pretty">
          Setiap sektor menceritakan kekayaan yang berbeda — dari sawah hingga sungai, 
          dari hutan hingga ladang. Inilah Kampung Lotaq dalam empat dimensi.
        </p>
      </div>
    </div>
  </section>

  <!-- Detail Potensi -->
  <section class="container-section py-20 md:py-28">
    <div class="space-y-24 md:space-y-32">
      {potensiUnggulan.map((potensi, index) => {
        const isReversed = index % 2 === 1;
        const warnaBg = potensi.warna === 'sunset' ? 'bg-sunset-50' : potensi.warna === 'sawah' ? 'bg-sawah-50' : 'bg-tanah-50';
        const warnaText = potensi.warna === 'sunset' ? 'text-sunset-700' : potensi.warna === 'sawah' ? 'text-sawah-700' : 'text-tanah-700';
        
        return (
          <article id={potensi.id} class="scroll-mt-24">
            <div class:list={[
              'grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center',
            ]}>
              <!-- Visual -->
              <div class:list={[
                'lg:col-span-5',
                isReversed ? 'lg:order-2' : 'lg:order-1'
              ]}>
                <div class={`aspect-square rounded-3xl ${warnaBg} p-12 flex items-center justify-center relative overflow-hidden`}>
                  <div class="absolute inset-0 pattern-dayak opacity-30"></div>
                  <div class="relative text-center">
                    <div class="text-8xl md:text-9xl mb-4">{potensi.icon}</div>
                    <p class={`font-headline text-2xl font-medium ${warnaText} italic`}>
                      {potensi.nama}
                    </p>
                  </div>
                </div>
              </div>

              <!-- Text Content -->
              <div class:list={[
                'lg:col-span-7',
                isReversed ? 'lg:order-1' : 'lg:order-2'
              ]}>
                <div class="flex items-center gap-4 mb-6">
                  <span class={`font-headline text-6xl font-bold ${warnaText} opacity-30 tabular-nums`}>
                    0{index + 1}
                  </span>
                  <span class={`text-xs uppercase tracking-[0.2em] font-display font-semibold ${warnaText}`}>
                    Potensi
                  </span>
                </div>
                
                <h2 class="font-headline text-4xl md:text-5xl font-medium text-tanah-900 leading-tight mb-6 text-balance">
                  {potensi.nama}
                </h2>
                
                <p class="text-lg text-tanah-600 leading-relaxed mb-4 text-pretty">
                  {potensi.deskripsi}
                </p>
                
                <p class="text-base text-tanah-700 leading-relaxed mb-8 text-pretty">
                  {potensi.detail}
                </p>

                <!-- Placeholder untuk konten lengkap -->
                <div class={`inline-flex items-center gap-2 px-4 py-2 rounded-full ${warnaBg} ${warnaText} text-sm font-display font-medium`}>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  Konten detail dalam pengembangan
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <!-- CTA -->
  <section class="container-section py-20">
    <div class="bg-gradient-to-br from-tanah-900 to-sunset-900 rounded-3xl p-12 md:p-16 text-center relative overflow-hidden">
      <div class="absolute inset-0 pattern-dayak opacity-50"></div>
      <div class="relative max-w-2xl mx-auto">
        <h2 class="font-headline text-3xl md:text-4xl font-medium text-white leading-tight mb-4">
          Tertarik bekerja sama?
        </h2>
        <p class="text-white/80 mb-8 text-lg">
          Hubungi pemerintah kampung untuk informasi peluang investasi, kerja sama, atau kunjungan.
        </p>
        <a href="/kontak" class="btn-primary bg-white !text-sunset-600 hover:!bg-krem-100">
          Hubungi Kami
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
