---
import BaseLayout from '../layouts/BaseLayout.astro';
import { beritaContoh } from '../data/kampung';

const formatTanggal = (tanggal: string) => {
  return new Date(tanggal).toLocaleDateString('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
};

const warnaKategori: Record<string, string> = {
  'Pemerintahan': 'bg-sunset-100 text-sunset-700',
  'Pertanian': 'bg-sawah-100 text-sawah-700',
  'Teknologi': 'bg-tanah-100 text-tanah-700',
  'Pembangunan': 'bg-emas-400/20 text-tanah-700',
};
---

<BaseLayout 
  title="Berita & Kegiatan"
  description="Berita terbaru, kegiatan, dan kabar dari Kampung Lotaq. Ikuti perkembangan pembangunan, sosial, dan budaya kampung."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-sunset-100 via-krem-100 to-sawah-100 pattern-dayak relative overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-10 right-10 w-72 h-72 bg-sunset-300/20 rounded-full blur-3xl"></div>
    </div>
    
    <div class="container-section py-20 md:py-24 relative">
      <div class="max-w-4xl">
        <div class="eyebrow mb-4">Berita & Kegiatan</div>
        <h1 class="headline-display text-tanah-900 mb-6 text-balance">
          Kabar dari <span class="highlight-brush">kampung</span>.
        </h1>
        <p class="text-xl text-tanah-700 leading-relaxed max-w-3xl text-pretty">
          Cerita, peristiwa, dan kemajuan yang terjadi setiap hari di Kampung Lotaq.
        </p>
      </div>
    </div>
  </section>

  <!-- Daftar Berita -->
  <section class="container-section py-20">
    <!-- Filter (placeholder) -->
    <div class="flex flex-wrap gap-2 mb-12">
      <button class="px-4 py-2 rounded-full bg-sunset-500 text-white text-sm font-display font-semibold">
        Semua
      </button>
      <button class="px-4 py-2 rounded-full bg-white border border-krem-300 text-tanah-700 text-sm font-display font-medium hover:border-sunset-300 transition-colors">
        Pemerintahan
      </button>
      <button class="px-4 py-2 rounded-full bg-white border border-krem-300 text-tanah-700 text-sm font-display font-medium hover:border-sunset-300 transition-colors">
        Pertanian
      </button>
      <button class="px-4 py-2 rounded-full bg-white border border-krem-300 text-tanah-700 text-sm font-display font-medium hover:border-sunset-300 transition-colors">
        Pembangunan
      </button>
      <button class="px-4 py-2 rounded-full bg-white border border-krem-300 text-tanah-700 text-sm font-display font-medium hover:border-sunset-300 transition-colors">
        Sosial Budaya
      </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {beritaContoh.map((berita) => (
        <article class="group card-warm flex flex-col h-full">
          <div class="aspect-[16/10] rounded-2xl bg-gradient-to-br from-sunset-200 to-sawah-200 mb-6 overflow-hidden relative">
            <div class="absolute inset-0 flex items-center justify-center text-tanah-600/40">
              <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
          </div>

          <div class="flex items-center gap-3 mb-3">
            <span class:list={['px-3 py-1 rounded-full text-xs font-display font-semibold', warnaKategori[berita.kategori] || 'bg-krem-100 text-tanah-700']}>
              {berita.kategori}
            </span>
            <time class="text-xs text-tanah-500" datetime={berita.tanggal}>
              {formatTanggal(berita.tanggal)}
            </time>
          </div>

          <h3 class="font-display font-bold text-xl text-tanah-900 leading-snug mb-3 group-hover:text-sunset-600 transition-colors">
            {berita.judul}
          </h3>
          <p class="text-tanah-600 leading-relaxed text-sm flex-1 mb-5">
            {berita.ringkasan}
          </p>

          <a 
            href={`/berita/${berita.slug}`}
            class="inline-flex items-center gap-2 text-sm font-display font-semibold text-sunset-600 group-hover:gap-3 transition-all"
          >
            Baca selengkapnya
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </article>
      ))}
    </div>

    <!-- Info -->
    <div class="mt-16 bg-krem-100 rounded-2xl p-8 text-center">
      <p class="text-tanah-600">
        Lebih banyak berita akan ditambahkan secara berkala oleh redaksi kampung.
      </p>
    </div>
  </section>
</BaseLayout>
