---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const berita = await getCollection('berita');
  return berita.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'berita'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formatTanggal = (tanggal: Date) => {
  return new Date(tanggal).toLocaleDateString('id-ID', {
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
};

const warnaKategori: Record<string, string> = {
  'Pemerintahan': 'bg-sunset-100 text-sunset-700',
  'Pertanian': 'bg-sawah-100 text-sawah-700',
  'Perkebunan': 'bg-tanah-100 text-tanah-700',
  'Perikanan': 'bg-sky-100 text-sky-700',
  'Wisata': 'bg-emas-400/20 text-tanah-700',
  'UMKM': 'bg-orange-100 text-orange-700',
  'Pembangunan': 'bg-stone-100 text-stone-700',
  'Sosial Budaya': 'bg-purple-100 text-purple-700',
  'PKK': 'bg-pink-100 text-pink-700',
  'Teknologi': 'bg-blue-100 text-blue-700',
  'Pemberdayaan': 'bg-sawah-100 text-sawah-700',
};

// Berita lain untuk related
const allBerita = await getCollection('berita');
const relatedBerita = allBerita
  .filter(b => b.slug !== entry.slug && b.data.kategori === entry.data.kategori)
  .slice(0, 3);
---

<BaseLayout 
  title={entry.data.judul}
  description={entry.data.ringkasan}
  image={entry.data.gambarUtama}
>
  <!-- Hero Berita dengan gambar utama -->
  <article>
    <header class="relative">
      <!-- Gambar Utama Full Width -->
      <div class="relative aspect-[16/9] md:aspect-[21/9] bg-gradient-to-br from-sunset-200 to-sawah-200 overflow-hidden">
        <img 
          src={entry.data.gambarUtama}
          alt={entry.data.gambarUtamaAlt}
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div class="absolute inset-0 hidden flex-col items-center justify-center text-tanah-600/40">
          <svg class="w-32 h-32" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <!-- Overlay gradient -->
        <div class="absolute inset-0 bg-gradient-to-t from-tanah-900/80 via-tanah-900/20 to-transparent"></div>
      </div>

      <!-- Meta info overlay -->
      <div class="container-section relative -mt-32 md:-mt-40 pb-8 z-10">
        <div class="max-w-4xl bg-white rounded-3xl shadow-2xl p-8 md:p-12 border border-krem-200">
          <!-- Breadcrumb -->
          <nav class="flex items-center gap-2 text-xs text-tanah-500 mb-6" aria-label="Breadcrumb">
            <a href="/" class="hover:text-sunset-600 transition-colors">Beranda</a>
            <span>/</span>
            <a href="/berita" class="hover:text-sunset-600 transition-colors">Berita</a>
            <span>/</span>
            <span class="text-tanah-700 truncate">{entry.data.kategori}</span>
          </nav>

          <!-- Kategori & Tanggal -->
          <div class="flex flex-wrap items-center gap-3 mb-6">
            <span class:list={['px-3 py-1 rounded-full text-xs font-display font-semibold', warnaKategori[entry.data.kategori] || 'bg-krem-100 text-tanah-700']}>
              {entry.data.kategori}
            </span>
            <time class="text-sm text-tanah-500 font-display" datetime={entry.data.tanggal.toISOString()}>
              📅 {formatTanggal(entry.data.tanggal)}
            </time>
          </div>

          <!-- Judul -->
          <h1 class="font-headline text-3xl md:text-5xl font-medium text-tanah-900 leading-tight mb-6 text-balance">
            {entry.data.judul}
          </h1>

          <!-- Ringkasan -->
          <p class="text-lg md:text-xl text-tanah-700 leading-relaxed mb-6 text-pretty font-display">
            {entry.data.ringkasan}
          </p>

          <!-- Penulis & Lokasi -->
          <div class="flex flex-wrap items-center gap-6 pt-6 border-t border-krem-200 text-sm">
            <div class="flex items-center gap-2">
              <div class="w-10 h-10 rounded-full bg-gradient-sunset flex items-center justify-center text-white font-display font-bold">
                R
              </div>
              <div>
                <p class="font-display font-semibold text-tanah-900">{entry.data.penulis}</p>
                <p class="text-xs text-tanah-500">Penulis</p>
              </div>
            </div>
            {entry.data.lokasi && (
              <div class="flex items-center gap-2 text-tanah-600">
                <svg class="w-5 h-5 text-sunset-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <span>{entry.data.lokasi}</span>
              </div>
            )}
          </div>
        </div>
      </div>
    </header>

    <!-- Konten Berita -->
    <div class="container-section pb-16">
      <div class="max-w-3xl mx-auto">
        <div class="prose prose-lg max-w-none 
                    prose-headings:font-headline prose-headings:font-medium prose-headings:text-tanah-900 
                    prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6
                    prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-4
                    prose-p:text-tanah-700 prose-p:leading-relaxed prose-p:text-pretty
                    prose-strong:text-tanah-900 prose-strong:font-semibold
                    prose-em:text-sunset-700 prose-em:not-italic prose-em:font-medium
                    prose-a:text-sunset-600 prose-a:no-underline hover:prose-a:underline
                    prose-blockquote:border-l-4 prose-blockquote:border-sunset-500 prose-blockquote:bg-krem-100 prose-blockquote:rounded-r-xl prose-blockquote:py-2 prose-blockquote:px-6 prose-blockquote:not-italic
                    prose-hr:border-krem-300">
          <Content />
        </div>

        <!-- Tags -->
        {entry.data.tags && entry.data.tags.length > 0 && (
          <div class="mt-12 pt-8 border-t border-krem-200">
            <p class="text-xs uppercase tracking-wider font-display font-semibold text-tanah-500 mb-4">Topik Terkait</p>
            <div class="flex flex-wrap gap-2">
              {entry.data.tags.map((tag) => (
                <span class="px-3 py-1.5 bg-krem-100 text-tanah-700 rounded-full text-xs font-display font-medium hover:bg-sunset-100 hover:text-sunset-700 transition-colors cursor-default">
                  #{tag.replace(/\s+/g, '')}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Share Section -->
        <div class="mt-10 pt-8 border-t border-krem-200">
          <p class="text-xs uppercase tracking-wider font-display font-semibold text-tanah-500 mb-4">Bagikan Berita</p>
          <div class="flex flex-wrap gap-3">
            <a 
              href={`https://wa.me/?text=${encodeURIComponent(entry.data.judul + ' - ' + Astro.url.toString())}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-sawah-500 hover:bg-sawah-600 text-white rounded-full text-sm font-display font-semibold transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
              </svg>
              WhatsApp
            </a>
            <a 
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.toString())}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-full text-sm font-display font-semibold transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              Facebook
            </a>
            <button
              onclick="navigator.clipboard.writeText(window.location.href).then(() => { this.innerHTML = '✓ Tersalin!'; setTimeout(() => location.reload(), 1500); })"
              class="inline-flex items-center gap-2 px-4 py-2 bg-tanah-700 hover:bg-tanah-800 text-white rounded-full text-sm font-display font-semibold transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
              Salin Link
            </button>
          </div>
        </div>
      </div>

      <!-- Galeri Foto -->
      {entry.data.galeri && entry.data.galeri.length > 0 && (
        <div class="max-w-6xl mx-auto mt-16 pt-12 border-t border-krem-200">
          <div class="eyebrow mb-4">Dokumentasi</div>
          <h2 class="font-headline text-3xl md:text-4xl font-medium text-tanah-900 leading-tight mb-8 text-balance">
            Galeri kegiatan.
          </h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
            {entry.data.galeri.map((foto, idx) => (
              <figure class="group">
                <div class="aspect-square rounded-2xl overflow-hidden bg-gradient-to-br from-sunset-200 to-sawah-200 relative">
                  <img 
                    src={foto.src}
                    alt={foto.alt}
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                    loading="lazy"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                  />
                  <div class="absolute inset-0 hidden flex-col items-center justify-center text-tanah-600/40">
                    <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                  </div>
                  <div class="absolute top-3 right-3 w-8 h-8 rounded-full bg-white/90 backdrop-blur-sm flex items-center justify-center text-xs font-display font-bold text-tanah-700">
                    {idx + 1}
                  </div>
                </div>
                {foto.caption && (
                  <figcaption class="mt-3 text-sm text-tanah-600 italic font-headline">
                    {foto.caption}
                  </figcaption>
                )}
              </figure>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>

  <!-- Related Berita -->
  {relatedBerita.length > 0 && (
    <section class="bg-krem-100 py-20">
      <div class="container-section">
        <div class="eyebrow mb-4">Berita Terkait</div>
        <h2 class="font-headline text-3xl md:text-4xl font-medium text-tanah-900 leading-tight mb-12 text-balance">
          Kabar lain dari {entry.data.kategori.toLowerCase()}.
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedBerita.map((berita) => (
            <a href={`/berita/${berita.slug}`} class="group card-warm flex flex-col h-full">
              <div class="aspect-[16/10] rounded-2xl bg-gradient-to-br from-sunset-200 to-sawah-200 mb-6 overflow-hidden relative">
                <img 
                  src={berita.data.gambarUtama}
                  alt={berita.data.gambarUtamaAlt}
                  class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  onerror="this.style.display='none';"
                />
              </div>

              <div class="flex items-center gap-3 mb-3">
                <span class:list={['px-3 py-1 rounded-full text-xs font-display font-semibold', warnaKategori[berita.data.kategori] || 'bg-krem-100 text-tanah-700']}>
                  {berita.data.kategori}
                </span>
                <time class="text-xs text-tanah-500">
                  {formatTanggal(berita.data.tanggal)}
                </time>
              </div>

              <h3 class="font-display font-bold text-xl text-tanah-900 leading-snug mb-3 group-hover:text-sunset-600 transition-colors flex-1">
                {berita.data.judul}
              </h3>

              <div class="inline-flex items-center gap-2 text-sm font-display font-semibold text-sunset-600 group-hover:gap-3 transition-all">
                Baca selengkapnya
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Kembali -->
  <section class="container-section py-16">
    <div class="text-center">
      <a href="/berita" class="btn-secondary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Kembali ke Daftar Berita
      </a>
    </div>
  </section>
</BaseLayout>
