---
import { getCollection } from 'astro:content';

const allBerita = await getCollection('berita');
const sortedBerita = allBerita
  .sort((a, b) => new Date(b.data.tanggal).valueOf() - new Date(a.data.tanggal).valueOf())
  .slice(0, 3);

const formatTanggal = (tanggal: Date) => {
  return new Date(tanggal).toLocaleDateString('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
};

const warnaKategori: Record<string, string> = {
  'Pemerintahan': 'bg-sunset-100 text-sunset-700',
  'Pertanian': 'bg-sawah-100 text-sawah-700',
  'Perkebunan': 'bg-tanah-100 text-tanah-700',
  'Perikanan': 'bg-sky-100 text-sky-700',
  'Wisata': 'bg-emas-400/20 text-tanah-700',
  'UMKM': 'bg-orange-100 text-orange-700',
  'Pembangunan': 'bg-stone-100 text-stone-700',
  'Sosial Budaya': 'bg-purple-100 text-purple-700',
  'PKK': 'bg-pink-100 text-pink-700',
  'Teknologi': 'bg-blue-100 text-blue-700',
  'Pemberdayaan': 'bg-sawah-100 text-sawah-700',
};
---

{sortedBerita.length > 0 && (
  <section class="bg-krem-50 py-20 md:py-28">
    <div class="container-section">
      <!-- Header -->
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
        <div class="max-w-2xl">
          <div class="eyebrow mb-4">Yang Terbaru</div>
          <h2 class="font-headline text-4xl md:text-5xl font-medium text-tanah-900 leading-tight text-balance">
            Kabar dari kampung.
          </h2>
        </div>
        <a href="/berita" class="inline-flex items-center gap-2 font-display font-semibold text-sunset-600 hover:text-sunset-700 transition-colors group">
          Semua Berita
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <!-- Grid Berita -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedBerita.map((berita) => (
          <a href={`/berita/${berita.slug}`} class="group card-warm flex flex-col h-full">
            <!-- Gambar -->
            <div class="aspect-[16/10] rounded-2xl bg-gradient-to-br from-sunset-200 to-sawah-200 mb-6 overflow-hidden relative">
              <img 
                src={berita.data.gambarUtama}
                alt={berita.data.gambarUtamaAlt}
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <div class="absolute inset-0 hidden flex-col items-center justify-center text-tanah-600/40">
                <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
            </div>

            <!-- Meta -->
            <div class="flex items-center gap-3 mb-3">
              <span class:list={['px-3 py-1 rounded-full text-xs font-display font-semibold', warnaKategori[berita.data.kategori] || 'bg-krem-100 text-tanah-700']}>
                {berita.data.kategori}
              </span>
              <time class="text-xs text-tanah-500" datetime={berita.data.tanggal.toISOString()}>
                {formatTanggal(berita.data.tanggal)}
              </time>
            </div>

            <!-- Konten -->
            <h3 class="font-display font-bold text-xl text-tanah-900 leading-snug mb-3 group-hover:text-sunset-600 transition-colors">
              {berita.data.judul}
            </h3>
            <p class="text-tanah-600 leading-relaxed text-sm flex-1 mb-5">
              {berita.data.ringkasan}
            </p>

            <div class="inline-flex items-center gap-2 text-sm font-display font-semibold text-sunset-600 group-hover:gap-3 transition-all">
              Baca selengkapnya
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
