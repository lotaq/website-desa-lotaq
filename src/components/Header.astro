---
import { kampung, navigasi } from '../data/kampung';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 bg-white/95 backdrop-blur-md border-b border-krem-200 shadow-sm">
  <div class="container-section">
    <nav class="flex items-center justify-between h-20" aria-label="Navigasi utama">
      <!-- Logo & Brand -->
      <a href="/" class="flex items-center gap-3 group">
        <img
          src="/logo-kutai-barat.png"
          alt="Lambang Kabupaten Kutai Barat"
          class="h-14 w-auto group-hover:scale-105 transition-transform"
        />
        <div class="hidden sm:block">
          <p class="font-display font-bold text-sm text-tanah-800 leading-tight">
            {kampung.namaLengkap}
          </p>
          <p class="text-xs text-tanah-500 leading-tight">
            {kampung.kabupaten}, {kampung.provinsi}
          </p>
        </div>
      </a>

      <!-- Menu Desktop -->
      <ul class="hidden md:flex items-center gap-1">
        {navigasi.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <li>
              <a 
                href={item.href}
                class:list={[
                  'px-4 py-2 rounded-full font-display text-sm font-medium transition-all duration-200',
                  isActive 
                    ? 'bg-sunset-100 text-sunset-700' 
                    : 'text-tanah-700 hover:bg-krem-100 hover:text-sunset-600'
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>

      <!-- Tombol Mobile Menu -->
      <button 
        id="mobile-menu-toggle"
        class="md:hidden p-2 rounded-lg hover:bg-krem-100 transition-colors"
        aria-label="Buka menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6 text-tanah-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </nav>

    <!-- Menu Mobile -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-krem-200">
      <ul class="flex flex-col gap-1 pt-3">
        {navigasi.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <li>
              <a 
                href={item.href}
                class:list={[
                  'block px-4 py-3 rounded-lg font-display text-base font-medium transition-colors',
                  isActive 
                    ? 'bg-sunset-100 text-sunset-700' 
                    : 'text-tanah-700 hover:bg-krem-100'
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Tutup menu' : 'Buka menu');
  });
</script>
