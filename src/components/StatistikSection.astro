---
import { statistik } from '../data/kampung';
---

<section class="container-section py-20 md:py-28">
  <div class="bg-gradient-to-br from-tanah-900 via-tanah-800 to-sunset-900 rounded-3xl p-10 md:p-16 relative overflow-hidden">
    <!-- Decorative -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-emas-400/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-sawah-500/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

    <div class="relative">
      <!-- Header -->
      <div class="max-w-2xl mb-12">
        <div class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] font-display font-semibold text-emas-400 mb-4">
          <span class="w-8 h-px bg-emas-400"></span>
          Kampung dalam Angka
        </div>
        <h2 class="font-headline text-4xl md:text-5xl font-medium text-white leading-tight text-balance">
          Cerita Kampung Lotaq, dalam <span class="text-emas-400 italic">data</span>.
        </h2>
      </div>

      <!-- Grid Statistik -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
        {statistik.map((stat) => (
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors">
            <div class="flex items-start justify-between mb-3">
              <span class="text-2xl" aria-hidden="true">{stat.icon}</span>
            </div>
            <div class="font-headline text-3xl md:text-4xl font-bold text-white mb-1 tabular-nums">
              {stat.nilai}
              {stat.satuan && <span class="text-base font-normal text-white/60 ml-1">{stat.satuan}</span>}
            </div>
            <p class="text-sm font-display font-semibold text-emas-400 mb-2">
              {stat.label}
            </p>
            <p class="text-xs text-white/50 leading-relaxed">
              {stat.catatan}
            </p>
          </div>
        ))}
      </div>

      <!-- Catatan footer -->
      <p class="text-xs text-white/40 mt-8 text-center md:text-left">
        Data dalam tahap pemutakhiran. Statistik terbaru akan dipublikasikan setelah verifikasi resmi.
      </p>
    </div>
  </div>
</section>
